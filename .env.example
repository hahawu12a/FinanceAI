# OpenAI API
OPENAI_API_KEY=your_openai_api_key_here

# Tushare API
TUSHARE_API_TOKEN=your_tushare_token_here

# Milvus
MILVUS_HOST=localhost
MILVUS_PORT=19530

# Pinecone (可选)
PINCONE_API_KEY=your_pinecone_key_here
PINCONE_ENVIRONMENT=your_environment_here

# LLM Configuration
OPENAI_MODEL=gpt-4
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2000

# Embedding Configuration
EMBEDDING_MODEL=openai
EMBEDDING_DIMENSION=1536

# Vector Store Configuration
VECTOR_STORE_TYPE=milvus
KNOWLEDGE_BASE_INDEX=finance_knowledge

# Analysis Configuration
ANALYSIS_LOOKBACK_DAYS=250

# 其他配置
DEBUG=True
LOG_LEVEL=INFO
